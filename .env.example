# circle-llc — example environment variables
# Copy to .env (which is gitignored) and fill in real values.
# NEVER commit .env

# ============================================================
# LLM Providers
# ============================================================

# Anthropic Claude (required for live mode; absent -> mock_mode)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional; used in gate_decider ensemble when ENSEMBLE_GATE_ENABLED=true)
OPENAI_API_KEY=sk-proj-...

# Google Gemini (optional; used in gate_decider ensemble AND fact-checker)
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-flash-latest

# ============================================================
# Feature flags
# ============================================================

# Activate multi-LLM ensemble in gate_decider (Claude + GPT + Gemini)
ENSEMBLE_GATE_ENABLED=true

# Let idea_enricher use Anthropic native web_search to ground claims
IDEA_ENRICHER_RESEARCH=true

# Let idea_enricher fact-check numerical claims with Gemini
FACT_CHECK_ENABLED=true

# ============================================================
# Closed-beta auth (R27 / ADR-010)
# ============================================================

# Comma-separated emails allowed to access the dashboard.
# Anyone NOT on this list gets 403 + their attempt is logged.
ALLOWED_EMAILS=crisan312@hotmail.com,jfnunez@asiservy.com,cristian.molina.ia.soporte@gmail.com

# ============================================================
# Anti-bot (R26 / ADR-009)
# ============================================================

# Optional: shared secret required in X-Gate-Secret header for /api/v1/gate/run.
# When set, all callers must include this header. Otherwise endpoint is public
# (still protected by rate-limit + tier quotas).
# GATE_RUN_SECRET=change-me-to-a-long-random-string

# Optional: Cloudflare Turnstile (free, no PII) for /api/v1/leads
# Get keys at https://dash.cloudflare.com -> Turnstile
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# Override rate-limit tiers (defaults shown). All optional.
# RL_FORM_BURST_MAX=5         # public_form burst max
# RL_FORM_BURST_WINDOW_S=60   # public_form burst window
# RL_FORM_DAILY_MAX=30        # public_form daily max per IP
# RL_LLM_BURST_MAX=2          # expensive_llm burst max
# RL_LLM_BURST_WINDOW_S=300   # expensive_llm burst window
# RL_LLM_DAILY_MAX=10         # expensive_llm daily max per IP
# MIN_FORM_DWELL_MS=3000      # min milliseconds between page load and submit

# Comma-separated extra CORS origins (e.g. preview deployments)
# EXTRA_ALLOWED_ORIGINS=https://preview.circles-ai.ai,https://staging.circles-ai.ai

# ============================================================
# Observability (R03 / ADR-004)
# ============================================================

# Langfuse self-hosted (optional). Agents trace silently if these are missing.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3001

# ============================================================
# Outcome DB (activate in M3 when N >= 3 factories)
# ============================================================

# OUTCOME_DB_WRITABLE=false
# DATABASE_URL=postgresql://user:pass@host:5432/circle_llc
