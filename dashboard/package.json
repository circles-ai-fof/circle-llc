{
  "name": "circles-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "clean": "node -e \"const fs=require('fs');['.next','tsconfig.tsbuildinfo','node_modules/.cache'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}));console.log('cleaned: .next, tsconfig.tsbuildinfo, node_modules/.cache')\"",
    "dev:clean": "npm run clean && npm run dev"
  },
  "dependencies": {
    "next": "15.5.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5",
    "tailwindcss": "^3.4.1",
    "postcss": "^8",
    "autoprefixer": "^10.0.1"
  }
}
