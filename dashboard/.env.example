# Dashboard env vars — copy to .env.local for local dev
# Vercel: configure these as "Environment Variables" in the project settings.
#
# All NEXT_PUBLIC_* are exposed to the browser. Never put secrets here.

# Backend API base URL.
#   Local dev: http://localhost:8002
#   Prod:      https://circle-llc-production.up.railway.app
#              (or your custom domain like https://api.circles-ai.ai)
NEXT_PUBLIC_API_URL=http://localhost:8002
